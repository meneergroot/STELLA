rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isVerified() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'meneergroot@proton.me'
      );
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- PORTFOLIO COLLECTION ---
    match /portfolio/{itemId} {
      function isValidPortfolioItem(data) {
        return data.keys().hasAll(['title', 'thumbnail', 'videoUrl', 'type', 'createdAt', 'createdBy']) &&
               data.keys().size() == 6 &&
               data.title is string && data.title.size() <= 200 &&
               data.thumbnail is string && data.thumbnail.size() <= 1000 &&
               data.videoUrl is string && data.videoUrl.size() <= 1000 &&
               data.type in ['video', 'short'] &&
               (
                 (request.auth != null && data.createdBy == request.auth.uid) ||
                 (request.auth == null && data.createdBy == 'anonymous')
               );
      }

      // Public can list and get
      allow get: if true;
      allow list: if true;

      // Only Admin or Unauthenticated Demo can create
      allow create: if (isAdmin() || request.auth == null) && 
                      isValidPortfolioItem(incoming()) && 
                      incoming().createdAt == request.time;

      // Only Admin or Unauthenticated Demo can update
      allow update: if (isAdmin() || request.auth == null) && 
                      isValidPortfolioItem(incoming()) && 
                      incoming().createdAt == existing().createdAt &&
                      incoming().createdBy == existing().createdBy;

      // Only Admin or Unauthenticated Demo can delete
      allow delete: if isAdmin() || request.auth == null;
    }

    // --- PRODUCTS COLLECTION ---
    match /products/{productId} {
      function isValidProduct(data) {
        return data.keys().hasAll(['title', 'description', 'stock', 'ean', 'price', 'imageUrls', 'createdAt', 'createdBy']) &&
               data.keys().size() == 8 &&
               data.title is string && data.title.size() <= 200 &&
               data.description is string && data.description.size() <= 5000 &&
               data.stock is int && data.stock >= 0 &&
               (data.price is int || data.price is float) && data.price >= 0 &&
               data.ean is string && data.ean.size() <= 64 &&
               data.imageUrls is list && data.imageUrls.size() <= 15 &&
               (
                 (request.auth != null && data.createdBy == request.auth.uid) ||
                 (request.auth == null && data.createdBy == 'anonymous')
               );
      }

      // Public can list and get
      allow get: if true;
      allow list: if true;

      // Only Admin or Unauthenticated Demo can create
      allow create: if (isAdmin() || request.auth == null) && 
                      isValidProduct(incoming()) && 
                      incoming().createdAt == request.time;

      // Only Admin or Unauthenticated Demo can update
      allow update: if (isAdmin() || request.auth == null) && 
                      isValidProduct(incoming()) && 
                      incoming().createdAt == existing().createdAt &&
                      incoming().createdBy == existing().createdBy;

      // Only Admin or Unauthenticated Demo can delete
      allow delete: if isAdmin() || request.auth == null;
    }

    // --- ADMINS COLLECTION ---
    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false; // Managed via Cloud Console or bootstrapping logic above
    }
  }
}
