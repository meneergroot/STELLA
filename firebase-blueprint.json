{
  "entities": {
    "PortfolioItem": {
      "title": "Portfolio Item",
      "description": "A video or short to be displayed in the portfolio",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the video" },
        "thumbnail": { "type": "string", "description": "URL to the thumbnail image" },
        "videoUrl": { "type": "string", "description": "The YouTube video URL or ID" },
        "type": { "type": "string", "enum": ["video", "short"], "description": "The type of content" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Server timestamp of creation" },
        "createdBy": { "type": "string", "description": "User ID of the uploader" }
      },
      "required": ["title", "thumbnail", "videoUrl", "type", "createdAt", "createdBy"]
    },
    "Admin": {
      "title": "Admin",
      "description": "User with admin privileges",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin"] }
      },
      "required": ["email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "An ecommerce product managed inside the WordPress-like admin dashboard",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the product" },
        "description": { "type": "string", "description": "Details and specs of the product" },
        "stock": { "type": "integer", "description": "Quantity available in store" },
        "ean": { "type": "string", "description": "European Article Number barcode" },
        "price": { "type": "number", "description": "Retail price" },
        "imageUrls": { "type": "array", "items": { "type": "string" }, "description": "Product images or render links" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Server timestamp of creation" },
        "createdBy": { "type": "string", "description": "User ID of the manager" }
      },
      "required": ["title", "description", "stock", "ean", "price", "imageUrls", "createdAt", "createdBy"]
    }
  },
  "firestore": {
    "portfolio": {
      "schema": "PortfolioItem",
      "description": "Collection of all drone footage items"
    },
    "admins": {
      "schema": "Admin",
      "description": "Whitelist of admin users"
    },
    "products": {
      "schema": "Product",
      "description": "Collection of ecommerce products for stock and sales"
    }
  }
}
